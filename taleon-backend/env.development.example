# 🚀 TaleOn Development Environment Variables
# Copy this file to .env and fill in your actual values

# Server Configuration
NODE_ENV=development
PORT=5000

# Database
MONGODB_URI=mongodb://localhost:27017/taleon

# JWT Authentication
JWT_SECRET=your_development_jwt_secret_key_here

# AI Service
GROQ_API_KEY=your_groq_api_key_here

# Frontend URL (for CORS and password reset links)
FRONTEND_URL=http://localhost:5173

# Email Configuration (for password reset)
# For Gmail, you'll need to use an App Password, not your regular password
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here
FROM_NAME=TaleOn Dev
FROM_EMAIL=noreply@yourdomain.com

# Optional: Additional Security
SESSION_SECRET=development_session_secret
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Optional: Logging
LOG_LEVEL=debug

# Google OAuth (for social login)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
